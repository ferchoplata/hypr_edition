{
  "ignore-gtk-theme": true,
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "overlay",
  "layer-shell": true,
  "layer-shell-cover-screen": true,
  "cssPriority": "user",
  "control-center-margin-top": 58,
  "control-center-margin-bottom": 12,
  "control-center-margin-right": 12,
  "control-center-margin-left": 12,
  "control-center-width": 430,
  "control-center-height": 680,
  "notification-window-width": 420,
  "fit-to-screen": false,
  "keyboard-shortcuts": true,
  "notification-grouping": true,
  "relative-timestamps": true,
  "transition-time": 180,
  "timeout": 7,
  "timeout-low": 4,
  "timeout-critical": 0,
  "hide-on-clear": false,
  "hide-on-action": true,
  "text-empty": "Todo esta al dia",
  "widgets": [
    "title",
    "dnd",
    "mpris",
    "buttons-grid",
    "volume",
    "slider#brightness",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Command Center",
      "clear-all-button": true,
      "button-text": "Limpiar"
    },
    "dnd": {
      "text": "No molestar"
    },
    "mpris": {
      "autohide": true,
      "show-album-art": "when-available",
      "loop-carousel": true,
      "blacklist": []
    },
    "buttons-grid": {
      "buttons-per-row": 3,
      "actions": [
        {
          "label": "󰖩  Wi-Fi",
          "type": "toggle",
          "active": true,
          "command": "sh -c '[ \"$SWAYNC_TOGGLE_STATE\" = true ] && nmcli radio wifi on || nmcli radio wifi off'",
          "update-command": "sh -c '[ \"$(nmcli radio wifi 2>/dev/null)\" = enabled ] && echo true || echo false'"
        },
        {
          "label": "󰂯  Bluetooth",
          "type": "toggle",
          "active": false,
          "command": "sh -c '[ \"$SWAYNC_TOGGLE_STATE\" = true ] && bluetoothctl power on || bluetoothctl power off'",
          "update-command": "sh -c 'bluetoothctl show 2>/dev/null | grep -q \"Powered: yes\" && echo true || echo false'"
        },
        {
          "label": "󰕾  Audio",
          "command": "pavucontrol"
        },
        {
          "label": "󰛳  Redes",
          "command": "nm-connection-editor"
        },
        {
          "label": "󰌾  Bloquear",
          "command": "hyprlock"
        },
        {
          "label": "  Energia",
          "command": "wlogout"
        }
      ]
    },
    "volume": {
      "label": "󰕾",
      "show-per-app": true,
      "show-per-app-icon": true,
      "show-per-app-label": true,
      "expand-per-app": false,
      "empty-list-label": "Sin aplicaciones reproduciendo audio",
      "expand-button-label": "󰐕",
      "collapse-button-label": "󰐍"
    },
    "slider#brightness": {
      "label": "󰃠",
      "cmd_getter": "sh -c 'brightnessctl -m 2>/dev/null | cut -d, -f4 | tr -d %'",
      "cmd_setter": "brightnessctl set $value%",
      "min": 1,
      "max": 100,
      "min_limit": 1,
      "max_limit": 100
    },
    "notifications": {
      "vexpand": true
    }
  }
}
