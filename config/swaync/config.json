{
  "ignore-gtk-theme": true,
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "overlay",
  "layer-shell": true,
  "layer-shell-cover-screen": true,
  "cssPriority": "user",
  "control-center-margin-top": 58,
  "control-center-margin-bottom": 12,
  "control-center-margin-right": 12,
  "control-center-margin-left": 12,
  "control-center-width": 430,
  "control-center-height": 680,
  "notification-window-width": 420,
  "fit-to-screen": false,
  "keyboard-shortcuts": true,
  "notification-grouping": true,
  "relative-timestamps": true,
  "transition-time": 180,
  "timeout": 7,
  "timeout-low": 4,
  "timeout-critical": 0,
  "hide-on-clear": false,
  "hide-on-action": true,
  "text-empty": "Todo esta al dia",
  "widgets": [
    "title",
    "dnd",
    "mpris",
    "buttons-grid",
    "volume",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Command Center",
      "clear-all-button": true,
      "button-text": "Limpiar"
    },
    "dnd": {
      "text": "No molestar"
    },
    "mpris": {
      "autohide": true,
      "show-album-art": "when-available",
      "loop-carousel": true,
      "blacklist": []
    },
    "buttons-grid": {
      "buttons-per-row": 2,
      "actions": [
        {
          "label": "󰖩  Wi-Fi",
          "type": "toggle",
          "active": true,
          "command": "sh -c 'timeout 2 nmcli -t -f TYPE device 2>/dev/null | grep -qx wifi || exit 0; if [ \"$SWAYNC_TOGGLE_STATE\" = true ]; then timeout 2 nmcli radio wifi on; else timeout 2 nmcli radio wifi off; fi'",
          "update-command": "sh -c 'timeout 2 nmcli -t -f TYPE device 2>/dev/null | grep -qx wifi || { echo false; exit 0; }; [ \"$(timeout 2 nmcli radio wifi 2>/dev/null)\" = enabled ] && echo true || echo false'"
        },
        {
          "label": "󰂯  Bluetooth",
          "type": "toggle",
          "active": false,
          "command": "sh -c 'systemctl is-active --quiet bluetooth.service || exit 0; if [ \"$SWAYNC_TOGGLE_STATE\" = true ]; then timeout 2 bluetoothctl power on; else timeout 2 bluetoothctl power off; fi'",
          "update-command": "sh -c 'systemctl is-active --quiet bluetooth.service || { echo false; exit 0; }; timeout 2 bluetoothctl show 2>/dev/null | grep -q \"Powered: yes\" && echo true || echo false'"
        },
        {
          "label": "󰕾  Audio",
          "command": "pavucontrol"
        },
        {
          "label": "󰛳  Redes",
          "command": "nm-connection-editor"
        },
        {
          "label": "󰌾  Bloquear",
          "command": "hyprlock"
        },
        {
          "label": "󰤄  Suspender",
          "command": "sh -c 'hyprlock & sleep 1; systemctl suspend'"
        },
        {
          "label": "󰜉  Reiniciar",
          "command": "systemctl reboot"
        },
        {
          "label": "  Apagar",
          "command": "systemctl poweroff"
        }
      ]
    },
    "volume": {
      "label": "󰕾",
      "show-per-app": true,
      "show-per-app-icon": true,
      "show-per-app-label": true,
      "expand-per-app": false,
      "empty-list-label": "Sin aplicaciones reproduciendo audio",
      "expand-button-label": "󰐕",
      "collapse-button-label": "󰐍"
    },
    "notifications": {
      "vexpand": true
    }
  }
}
